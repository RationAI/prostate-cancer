{
    "$schema": "https://gitlab.com/empaia/integration/definitions/-/raw/main/ead/ead-schema.v3.json",
    "name": "Cancer Detection",
    "name_short": "PCD",
    "namespace": "org.empaia.rationai.cancer_detection.v3.0",
    "description": "Overlay displaying probability of cancerous tissue in image patches",
    "io": {
        "my_wsi": {
            "type": "wsi"
        },
        "background_mask": {
            "reference": "io.my_wsi",
            "type": "string"
        },
        "probability_mask": {
            "reference": "io.my_wsi",
            "type": "string"
        }
    },
    "modes": {
        "preprocessing": {
            "inputs": [
                "my_wsi"
            ],
            "outputs": [
                "background_mask",
                "probability_mask"
            ]
        }
    }
}