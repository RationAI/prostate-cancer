{
    "$schema": "https://gitlab.com/empaia/integration/definitions/-/raw/main/ead/ead-schema.v3.json",
    "name": "Prostate Cancer",
    "name_short": "PC1",
    "namespace": "org.empaia.rationai.prostate_cancer.v3.0",
    "description": "Binary classifier for prostate cancer",
    "classes": {
        "background": {
            "name": "Background",
            "description": "Binary background mask"
        },
        "tissue": {
            "name": "Tissue",
            "description": "Valid tissue particles"
        },
        "cancer_probability": {
            "name": "Cancer probability",
            "description": "Cancer probability score"
        }
    },
    "io": {
        "my_wsi": {
            "type": "wsi"
        },
        "background_mask": {
            "type": "continuous_pixelmap",
            "reference": "io.my_wsi",
            "channel_classes": [
                "org.empaia.rationai.prostate_cancer.v3.0.classes.background"
            ]
        },
        "probability_mask": {
            "type": "continuous_pixelmap",
            "reference": "io.my_wsi",
            "channel_classes": [
                "org.empaia.rationai.prostate_cancer.v3.0.classes.cancer_probability"
            ]
        }
    },
    "modes": {
        "preprocessing": {
            "inputs": [
                "my_wsi"
            ],
            "outputs": [
                "background_mask",
                "probability_mask"
            ]
        }
    }
}